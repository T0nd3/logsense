# Log-Analyzer / LogSense config example — copy to config.yaml and adapt

pii_salt: ""           # set here or via LOGSENSE_PII_SALT env var
db_path: logsense.db  # use /data/logsense.db inside Docker
pii_rules_path: pii_rules.yaml

# REST API auth — leave empty to disable (local dev / Docker with firewall)
# Set via env var LOGSENSE_API_TOKEN or here (prefer env var)
api_token: ""

# Plugin directory — *.py files here are auto-loaded at startup
# plugins_dir: plugins/

# Finding retention and minimum severity for --track-errors persistence
# findings_retention_days: 30
# findings_min_severity: high

llm:
  provider: ollama
  model: gemma3:4b
  endpoint: http://localhost:11434
  temperature: 0.1
  max_context_tokens: 8000

opensearch:
  host: localhost
  port: 9200
  use_ssl: false
  verify_certs: true

  # Auth — prefer env vars over plain-text credentials in this file:
  #   OPENSEARCH_USERNAME / OPENSEARCH_PASSWORD
  #   OPENSEARCH_API_KEY
  #   OPENSEARCH_CLIENT_CERT / OPENSEARCH_CLIENT_KEY / OPENSEARCH_CA_CERTS
  #
  # username: myuser
  # password: secret
  # api_key: "keyid:base64encodedkey"
  # ca_certs: /etc/ssl/certs/my-ca.pem
  # client_cert: /etc/ssl/certs/client.pem
  # client_key: /etc/ssl/private/client.key

  # Index and field mapping defaults
  default_index: "logstash-*"
  timestamp_field: "@timestamp"
  message_field: "message"
  severity_field: "level"
  source_name_field: "host.name"
